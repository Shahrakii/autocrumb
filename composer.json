{
    "name": "shahrakii/autocrumb",
    "description": "Automatic translated breadcrumbs from URL segments in Laravel – perfect for multilingual admin panels",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Shahryar",
            "email": "Shahryar.sky2014@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "shahrakii\\Autocrumb\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "shahrakii\\Autocrumb\\AutocrumbServiceProvider"
            ],
            "aliases": {
                "Autocrumb": "shahrakii\\Autocrumb\\Facades\\Autocrumb"
            }
        }
    }
}