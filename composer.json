{
    "name": "shahrakii/autocrumb",
    "description": "Automatic breadcrumb generator for Laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Shahrakii\\Autocrumb\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shahrakii\\Autocrumb\\AutocrumbServiceProvider"
            ],
            "aliases": {
                "Autocrumb": "Shahrakii\\Autocrumb\\Facades\\Autocrumb"
            }
        }
    }
}